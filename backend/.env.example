# ============================================================
# MiTienda Backend — Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Completar cada variable con los valores reales.
#   3. NUNCA versionar el archivo .env.
#   4. Este archivo (.env.example) SÍ se versiona, sin valores reales.
# ============================================================


# ============================================================
# ENTORNO
# ============================================================

# Valores posibles: development | test | production
NODE_ENV=development


# ============================================================
# BASE DE DATOS — PostgreSQL
# ============================================================

# Formato: postgres://usuario:contraseña@host:puerto/base_de_datos
# Desarrollo:
DATABASE_URL=postgres://mitienda_user:mitienda_pass@localhost:5432/mitienda_dev

# Test (usar para ejecutar pruebas):
# DATABASE_URL=postgres://mitienda_user:mitienda_pass@localhost:5432/mitienda_test

# Producción (configurar en el servidor, no en este archivo):
# DATABASE_URL=postgres://usuario:contraseña@host:5432/mitienda_prod


# ============================================================
# SEGURIDAD — JWT y Cookies
# ============================================================

# Secretos para firma de tokens JWT y cookies de sesión.
# IMPORTANTE: Cambiar por valores aleatorios seguros en producción.
# Generar con: openssl rand -base64 32
JWT_SECRET=cambia_este_secreto_por_uno_seguro_en_produccion
COOKIE_SECRET=cambia_este_secreto_por_uno_seguro_en_produccion


# ============================================================
# CORS — Orígenes permitidos
# ============================================================

# Frontend de la tienda (Next.js — Sprint 6)
STORE_CORS=http://localhost:3000

# Panel administrativo de Medusa
ADMIN_CORS=http://localhost:9000

# Orígenes permitidos para autenticación (separados por coma)
AUTH_CORS=http://localhost:3000,http://localhost:9000


# ============================================================
# BACKEND URL
# ============================================================

# URL base del servidor Medusa (usada por el admin dashboard)
MEDUSA_BACKEND_URL=http://localhost:9000


# ============================================================
# VARIABLES FUTURAS — No activar hasta el sprint correspondiente
# ============================================================

# Redis (Sprint 7 — Cache y sesiones)
REDIS_URL=redis://localhost:6379

# Meilisearch (Sprint 8 — Búsqueda avanzada)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=tu_api_key_de_meilisearch
